PORT=
MONGO_URI=mongodb+srv://<db_user>:<password>@<cluster-host>/hms?retryWrites=true&w=majority&appName=Cluster0
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=
CLOUDINARY_NAME=
# Cloudinary is optional. If omitted, uploaded doctor images are served locally
# from /uploads instead.
ADMIN_EMAIL=
ADMIN_PASSWORD=
JWT_SECRET=
# Razorpay (https://dashboard.razorpay.com/) — use Test mode keys for development
# Key Id is public (safe in frontend). Key Secret must stay only on the server.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
CURRENCY=INR
