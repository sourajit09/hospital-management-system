# Local dev: leave empty so Vite proxies /api to the backend (vite.config.js).
VITE_BACKEND_URL=

# Optional: same Key Id as backend RAZORPAY_KEY_ID (checkout can also load it from /api/user/razorpay-key).
VITE_RAZORPAY_KEY_ID=

# Navbar link to admin/doctor panel (default local Vite port).
VITE_ADMIN_PANEL_URL=http://localhost:5174/

VITE_CURRENCY_SYMBOL=₹
